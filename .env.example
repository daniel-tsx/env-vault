# Database
# Get your Neon connection string from https://neon.tech
DATABASE_URL=

# BetterAuth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Encryption key for environment variable values (AES-256-GCM, 32 bytes).
# Generate with: openssl rand -hex 32
# This is exposed internally as key id "0" and is the default key for new writes.
ENCRYPTION_KEY=

# --- Key rotation (optional) ---
# To rotate keys without downtime:
#   1. Generate a new key:  openssl rand -hex 32
#   2. Add it here under a new id and keep the old ENCRYPTION_KEY (id "0") set:
#        ENCRYPTION_KEYS={"1":"<new 64-hex key>"}
#   3. Point new writes at it:
#        ENCRYPTION_PRIMARY_KEY_ID=1
#   4. Re-encrypt existing data:  pnpm rotate-keys --apply
#   5. Once complete, the old key may be removed.
# ENCRYPTION_KEYS=
# ENCRYPTION_PRIMARY_KEY_ID=

# Database
# Get your Neon connection string from https://neon.tech
DATABASE_URL=

# BetterAuth
# Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000

# Encryption key for environment variable values
# Generate with: openssl rand -hex 32
# This is used for AES-256-GCM encryption (32 bytes = 256 bits)
ENCRYPTION_KEY=
